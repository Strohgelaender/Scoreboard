{
	"name": "scoreboard",
	"version": "1.0.0",
	"description": "Small Helper Program that generates Stream-Overlay-Scoreboards",
	"main": "src/index.js",
	"scripts": {
		"start": "node src/main.js",
		"dev": "nodemon src/main.js",
		"lineup": "node src/AufstellungParser.js",
		"lineup:dev": "nodemon src/AufstellungParser.js",
		"update": "ncu -i --format group",
		"prettier": "npx prettier . --write"
	},
	"author": "Strohgelaender",
	"type": "module",
	"engines": {
		"node": ">=22.10.0"
	},
	"dependencies": {
		"@elgato-stream-deck/node": "7.6.1",
		"@julusian/jpeg-turbo": "2.2.0",
		"axios": "1.13.6",
		"body-parser": "2.2.2",
		"dotenv": "16.5.0",
		"express": "5.2.1",
		"node-html-parser": "7.1.0",
		"obs-websocket-js": "5.0.8",
		"sharp": "0.34.2",
		"tinyws": "^0.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.28.0",
		"eslint": "^9.28.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^16.2.0",
		"nodemon": "^3.1.14",
		"npm-check-updates": "^18.0.1",
		"prettier": "3.8.1"
	}
}
